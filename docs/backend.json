
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role mapping.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID." },
        "email": { "type": "string", "format": "email", "description": "Registered email." },
        "role": { "type": "string", "enum": ["admin", "seller"], "description": "The assigned role. Defaults to seller." },
        "displayName": { "type": "string", "description": "Full name." }
      },
      "required": ["uid", "email"]
    },
    "Product": {
      "title": "Product Item",
      "description": "Items available for sale in the shop.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Sale": {
      "title": "Sale Record",
      "description": "Transaction details.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "total": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "qty": { "type": "number" }
            }
          }
        },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense Record",
      "description": "Business costs.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "sellerId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles. Authenticated users can read their own. Admins can read all."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Shop inventory. Anyone can read. Only admins can write."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records. Sellers can create. Only admins can read all."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Expense records. Sellers can create. Only admins can read all."
    }
  }
}
