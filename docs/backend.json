
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user and their assigned role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["owner", "seller"] },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Sale": {
      "title": "Sale Record",
      "description": "A record of a transaction made by a seller.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "total": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "qty": { "type": "number" }
            }
          }
        },
        "sellerId": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense Record",
      "description": "A record of business costs.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "sellerId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Allows a user to read and write their own profile document where the document ID matches their authenticated UID."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Any authenticated user can create a sale. Users with the owner role can read all sales documents."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Any authenticated user can create an expense. Users with the owner role can read all expense documents."
    }
  }
}
