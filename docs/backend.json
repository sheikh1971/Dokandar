
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and role mapping.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID." },
        "email": { "type": "string", "format": "email", "description": "Registered email." },
        "role": { "type": "string", "enum": ["owner", "seller"], "description": "The assigned role. If missing, defaults to seller." },
        "displayName": { "type": "string", "description": "Full name." }
      },
      "required": ["uid", "email"]
    },
    "Sale": {
      "title": "Sale Record",
      "description": "Transaction details.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "total": { "type": "number" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "qty": { "type": "number" }
            }
          }
        },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense Record",
      "description": "Business costs.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "sellerId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document. A user can read their own profile. Only users with the 'owner' role in their own profile document can read other users' profiles."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records. Any authenticated user can create a sale. Only users whose profile document has role 'owner' can read all sales."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Expense records. Any authenticated user can create an expense. Only users whose profile document has role 'owner' can read all expenses."
    }
  }
}
